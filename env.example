# Expert Agent MCP Server - Environment Variables Example

# Database Configuration
CLOUD_DOG__EXPERT__DB__URI=sqlite:///expert.db
# For PostgreSQL: CLOUD_DOG__EXPERT__DB__URI=postgresql://user:password@localhost:5432/expert
# For MySQL: CLOUD_DOG__EXPERT__DB__URI=mysql://user:password@localhost:3306/expert

# Default Expert Configuration
CLOUD_DOG__EXPERT__DEFAULT_EXPERT=_DEFAULT_

# LLM Configuration
CLOUD_DOG__EXPERT__LLM__PROVIDER=ollama
CLOUD_DOG__EXPERT__LLM__BASE_URL=http://localhost:11434
CLOUD_DOG__EXPERT__LLM__MODEL=qwen3:14b

# Server Ports
CLOUD_DOG__EXPERT__API_SERVER__PORT=8083
CLOUD_DOG__EXPERT__WEB_SERVER__PORT=8080
CLOUD_DOG__EXPERT__MCP_SERVER__PORT=8081
CLOUD_DOG__EXPERT__A2A_SERVER__PORT=8082

# Session Management
CLOUD_DOG__EXPERT__SESSION__DEFAULT_TTL_HOURS=24
CLOUD_DOG__EXPERT__SESSION__HISTORY_RETENTION_DAYS=30

# Authentication
CLOUD_DOG__EXPERT__AUTH__PROVIDER=local
CLOUD_DOG__EXPERT__AUTH__JWT_SECRET=your_jwt_secret_here
CLOUD_DOG__EXPERT__WEB_SERVER__ADMIN_USER=admin
CLOUD_DOG__EXPERT__WEB_SERVER__ADMIN_PASSWORD=changeme

# Logging
CLOUD_DOG__EXPERT__LOG__LEVEL=INFO
CLOUD_DOG__EXPERT__LOG__PII_REDACTION=true

# Privacy & PII Management
CLOUD_DOG__EXPERT__PRIVACY__PII_REMOVAL_ENABLED=true
CLOUD_DOG__EXPERT__PRIVACY__DATA_ENCRYPTION_AT_REST=true

# code-runner A2A consumer (W28I-1218)
# Lets the agent run code on the code-runner service via the code.execute skill.
CLOUD_DOG__EXPERT__CODE_RUNNER__BASE_URL=https://codemcpserver0.cloud-dog.net
CLOUD_DOG__EXPERT__CODE_RUNNER__API_KEY=your_code_runner_api_key_here
# CLOUD_DOG__EXPERT__CODE_RUNNER__TIMEOUT_SECONDS=60
# CLOUD_DOG__EXPERT__CODE_RUNNER__VERIFY_TLS=true
# CLOUD_DOG__EXPERT__CODE_RUNNER__DEFAULT_LANGUAGE=python

# Vector Store Configuration (Chroma example)
CLOUD_DOG__EXPERT__VECTOR_STORES__CHROMA__DEFAULT__HOST=localhost
CLOUD_DOG__EXPERT__VECTOR_STORES__CHROMA__DEFAULT__PORT=8000
CLOUD_DOG__EXPERT__VECTOR_STORES__CHROMA__DEFAULT__COLLECTION_NAME=expert_default

# Identity Provider Configuration
# For Google authentication:
# CLOUD_DOG__EXPERT__AUTH__GOOGLE__CLIENT_ID=your_google_client_id
# CLOUD_DOG__EXPERT__AUTH__GOOGLE__CLIENT_SECRET=your_google_client_secret

# For LinkedIn authentication:
# CLOUD_DOG__EXPERT__AUTH__LINKEDIN__CLIENT_ID=your_linkedin_client_id
# CLOUD_DOG__EXPERT__AUTH__LINKEDIN__CLIENT_SECRET=your_linkedin_client_secret

# For Keycloak:
# CLOUD_DOG__EXPERT__AUTH__KEYCLOAK__SERVER_URL=https://your-keycloak-server.com
# CLOUD_DOG__EXPERT__AUTH__KEYCLOAK__REALM=your_realm
