# Private folder (contains PII, credentials, API keys)
private/
# But allow non-secret env files (they are needed for reference)
!private/env-test
!private/env-integration
!private/env-application
!private/env-build
!private/env-docker
!private/README.md
# Exclude all secrets files
private/*-secrets
private/env-*-secrets

# Transient folders (excluded from git)
# Local archive (never commit)
archive/
# Temporary working files - can be deleted at any time
working/
# Local running/server development/project storage
storage/
# Log files
logs/
# PID files
.pids/
# Local runtime state (absolute paths, private env references — never publish/commit)
.run/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

