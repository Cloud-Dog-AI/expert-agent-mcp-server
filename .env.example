# Expert Agent MCP Server - local non-secret example
# Copy to a local env file and pass with --env where required.

# Core service ports (expert-agent assignment)
CLOUD_DOG__EXPERT__API_SERVER__HOST=127.0.0.1
CLOUD_DOG__EXPERT__API_SERVER__PORT=8030
CLOUD_DOG__EXPERT__WEB_SERVER__HOST=127.0.0.1
CLOUD_DOG__EXPERT__WEB_SERVER__PORT=8031
CLOUD_DOG__EXPERT__MCP_SERVER__HOST=127.0.0.1
CLOUD_DOG__EXPERT__MCP_SERVER__PORT=8032
CLOUD_DOG__EXPERT__A2A_SERVER__HOST=127.0.0.1
CLOUD_DOG__EXPERT__A2A_SERVER__PORT=8033

# API/auth
CLOUD_DOG__EXPERT__API_KEY=replace-with-test-key
CLOUD_DOG__EXPERT__AUTH__PROVIDER=local
CLOUD_DOG__EXPERT__AUTH__JWT_SECRET=replace-with-local-secret

# Database
CLOUD_DOG__EXPERT__DB__URI=sqlite:///expert.db
CLOUD_DOG__EXPERT__DB__ECHO=false

# LLM defaults
CLOUD_DOG__EXPERT__LLM__PROVIDER=ollama
CLOUD_DOG__EXPERT__LLM__BASE_URL=http://127.0.0.1:11434
CLOUD_DOG__EXPERT__LLM__MODEL=qwen3:14b
CLOUD_DOG__EXPERT__LLM__TIMEOUT=300

# Embeddings
CLOUD_DOG__EXPERT__EMBEDDINGS__PROVIDER=ollama
CLOUD_DOG__EXPERT__EMBEDDINGS__BASE_URL=http://127.0.0.1:11434
CLOUD_DOG__EXPERT__EMBEDDINGS__MODEL=bge-m3:567m
CLOUD_DOG__EXPERT__EMBEDDINGS__DIMENSION=1024

# Logging
CLOUD_DOG__EXPERT__LOG__LEVEL=INFO
CLOUD_DOG__EXPERT__LOG__PII_REDACTION=true

# Session controls
CLOUD_DOG__EXPERT__SESSION__DEFAULT_TTL_HOURS=24
CLOUD_DOG__EXPERT__SESSION__HISTORY_RETENTION_DAYS=30
CLOUD_DOG__EXPERT__SESSION__MAX_SESSIONS_PER_USER=10
CLOUD_DOG__EXPERT__SESSION__MAX_SESSIONS_PER_GROUP=50
CLOUD_DOG__EXPERT__SESSION__QUEUE_ENABLED=true

# Put local-only runtime values in this file or pass them as shell environment variables.
